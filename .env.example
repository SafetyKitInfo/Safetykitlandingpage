# Example environment variables for local development
# Copy this file to `.env.local` and fill in real values. Do NOT commit `.env.local`.

# SendGrid API key (create in SendGrid dashboard => Settings → API Keys)
SENDGRID_API_KEY=YOUR_SENDGRID_API_KEY_HERE

# Where contact form submissions are sent
CONTACT_RECEIVER_EMAIL=info.safetykit@gmail.com

# From address used when sending emails
CONTACT_FROM_EMAIL=no-reply@safetykit.com.au

# If you want to explicitly force real SendGrid sends in development (use with
# caution), set this to `true`. This requires a valid `SENDGRID_API_KEY` and
# a SendGrid-verified `CONTACT_FROM_EMAIL`.
FORCE_SENDGRID_SEND=false

# Set to `true` to disable SendGrid sending entirely (useful for CI or local dev)
# DISABLE_SENDGRID=true

# Optional SMTP fallback (useful if you prefer SMTP or SendGrid is unavailable)
# Set `ENABLE_SMTP_FALLBACK=true` and provide the following credentials.
# Example for Gmail with an App Password: SMTP_HOST=smtp.gmail.com, SMTP_PORT=465, SMTP_SECURE=true
ENABLE_SMTP_FALLBACK=false
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional: override the canonical site URL used in <head> meta tags and structured data
# Set this to your production domain (e.g. https://safetysight.com.au)
NEXT_PUBLIC_SITE_URL=

# Optional: direct Formspree endpoint so the front-end can POST directly
# Example: NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/XXXXXXXX
NEXT_PUBLIC_FORMSPREE_ENDPOINT=
