# Example environment variables for local development
# Copy this file to `.env.local` and fill in real values. Do NOT commit `.env.local`.

# SendGrid API key (create in SendGrid dashboard => Settings → API Keys)
SENDGRID_API_KEY=YOUR_SENDGRID_API_KEY_HERE

# Where contact form submissions are sent
CONTACT_RECEIVER_EMAIL=info.safetykit@gmail.com

# From address used when sending emails
CONTACT_FROM_EMAIL=no-reply@safetykit.com.au
